# import the mne and the matplotlib database

import mne
from mne.datasets import sample
import matplotlib.pyplot as plt
%matplotlib qt

# download the raw data from MNE offical database/ input the data from the local computer
# data formate: .fif (*raw data or preprocessing data)

fname = mne.datasets.sample.data_path()
sample_data_raw_file = (
    fname / "MEG" / "sample" / "sample_audvis_filt-0-40_raw.fif"
)
raw = mne.io.read_raw_fif(sample_data_raw_file)

# plot the raw data and control the psd
print(raw)
print(raw.info)
raw.compute_psd(fmax=50).plot(picks="data", exclude="bads", amplitude=False)
raw.plot(star=20, duration=5, n_channels=30)
raw.set_channel_types({'VEOG'='eog'})
raw.pick=(picks='all', exclude=['HEOG','trigger']

import os

from mne.preprocessing import ICA, corrmap, create_ecg_epochs, create_eog_epochs

# preprocessing
# set up and fit the ICA
ica = mne.preprocessing.ICA(n_components=20, random_state=97, max_iter=800)

# read the raw data's parameter
raw.crop(tmax=60.0).pick(picks=["mag", "eeg", "stim", "eog"])
raw.load_data()

# If you lose the sklearn package, please reload it use the following code
import sklearn
print(sklearn.__version__)

ica.fit(raw)

ica.exclude = [1, 2]  # details on how we picked these are omitted here
ica.plot_properties(raw, picks=ica.exclude)

orig_raw = raw.copy()
raw.load_data()
ica.apply(raw)

